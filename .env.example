# Discord bot token from the Discord Developer Portal.
# Never commit the real token.
DISCORD_TOKEN=

# Optional public metadata. The application ID is public; the public key is only
# needed for HTTP interactions, which SOLANE API does not use in beta.
DISCORD_APPLICATION_ID=1498868232386510948
DISCORD_PUBLIC_KEY=

# Solane API is the source of truth. In Docker on the VPS, this should be the
# private Docker network name.
SOLANE_API_BASE_URL=http://solane-api:8000
SOLANE_BOT_API_KEY=

# Persistent message targets. Use the same channel for multiple panels if wanted.
DISCORD_RISK_CHANNEL_ID=
DISCORD_PIPES_CHANNEL_ID=
DISCORD_POCHVEN_CHANNEL_ID=
DISCORD_LOWSEC_CHANNEL_ID=
DISCORD_CORRUPTION_CHANNEL_ID=
DISCORD_SERVICE_CHANNEL_ID=

# Runtime behavior.
BOT_POLL_SECONDS=300
BOT_STATE_PATH=data/solane-ai-state.json
BOT_LOG_LEVEL=INFO
